# ── Telegram Bot ────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=8277251879:AAGJQd0316xU2l70p3St2irpRmCsE4rKX6g

# Chat ID to receive notifications.
# How to find it:
#   1. Start a conversation with your bot (send it any message).
#   2. Open https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates in a browser.
#   3. Look for "chat":{"id": <number>} — that number is your TELEGRAM_CHAT_ID.
TELEGRAM_CHAT_ID=

# ── Gmail (for email notifications) ─────────────────────────────────────────────
# Generate a Gmail App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on.
#   3. Go to App Passwords → select "Mail" → generate.
#   4. Paste the 16-character password below (spaces optional).
EMAIL_PASS=

# ── Server ───────────────────────────────────────────────────────────────────────
# Set to "production" on Railway to serve static files from ./dist
NODE_ENV=production
PORT=3001
